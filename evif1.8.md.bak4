## 🎯 Phase 5: 增强CLI (Week 5)

### 目标
实现完整的 CLI,支持 50+ 命令对等 AGFS Shell

### CLI 架构

```rust
// evif-cli/src/main.rs

use clap::{Parser, Subcommand};
use evif_client::EvifClient;

#[derive(Parser)]
#[command(name = "evif")]
#[command(about = "EVIF - Everything is a File System", long_about = None)]
struct Cli {
    #[command(subcommand)]
    command: Commands,
}

#[derive(Subcommand)]
enum Commands {
    /// 列出文件和目录
    Ls {
        /// 路径
        path: String,
        /// 限制数量
        #[arg(short, long)]
        limit: Option<usize>,
        /// 显示详细信息
        #[arg(short, long)]
        detailed: bool,
    },

    /// 读取文件内容
    Cat {
        /// 文件路径
        path: String,
        /// 偏移量
        #[arg(short, long, default_value_t = 0)]
        offset: u64,
        /// 读取大小
        #[arg(short, long, default_value_t = 0)]
        size: u64,
    },

    /// 写入文件
    Write {
        /// 文件路径
        path: String,
        /// 内容 (从 stdin 或参数)
        content: Option<String>,
        /// 从文件读取
        #[arg(short, long)]
        file: Option<String>,
        /// 追加模式
        #[arg(short, long)]
        append: bool,
    },

    /// 删除文件
    Rm {
        /// 文件路径
        path: String,
        /// 递归删除
        #[arg(short, long)]
        recursive: bool,
        /// 强制删除
        #[arg(short, long)]
        force: bool,
    },

    /// 创建目录
    Mkdir {
        /// 目录路径
        path: String,
        /// 权限
        #[arg(short, long, default_value_t = 0o755)]
        mode: u32,
        /// 递归创建
        #[arg(short, long)]
        parents: bool,
    },

    /// 移动/重命名文件
    Mv {
        /// 源路径
        src: String,
        /// 目标路径
        dst: String,
    },

    /// 复制文件
    Cp {
        /// 源路径
        src: String,
        /// 目标路径
        dst: String,
    },

    /// 获取文件信息
    Stat {
        /// 文件路径
        path: String,
        /// JSON 格式输出
        #[arg(short, long)]
        json: bool,
    },

    /// 挂载插件
    Mount {
        /// 插件名称
        plugin: String,
        /// 挂载路径
        path: String,
        /// 配置参数 (JSON)
        #[arg(short, long)]
        config: Option<String>,
    },

    /// 卸载插件
    Unmount {
        /// 挂载路径
        path: String,
    },

    /// 列出挂载点
    Mounts,

    /// 交互式 REPL 模式
    Repl,

    /// Grep 搜索
    Grep {
        /// 搜索路径
        path: String,
        /// 搜索模式
        pattern: String,
        /// 结果限制
        #[arg(short, long, default_value_t = 10)]
        limit: usize,
    },

    /// 向量搜索
    Vector {
        #[command(subcommand)]
        cmd: VectorCommands,
    },

    /// GPT 操作
    Gpt {
        #[command(subcommand)]
        cmd: GptCommands,
    },

    /// 队列操作
    Queue {
        #[command(subcommand)]
        cmd: QueueCommands,
    },

    /// 健康检查
    Health,

    /// 服务器信息
    ServerInfo,

    /// 版本信息
    Version,
}

#[derive(Subcommand)]
enum VectorCommands {
    /// 添加文档
    Add {
        namespace: String,
        file_path: String,
    },
    /// 搜索文档
    Search {
        namespace: String,
        query: String,
        #[arg(short, long, default_value_t = 5)]
        top_k: usize,
    },
    /// 列出命名空间
    ListNs,
}

#[derive(Subcommand)]
enum GptCommands {
    /// 处理文本
    Process {
        file_path: String,
        #[arg(short, long)]
        action: String,
    },
    /// 查询任务状态
    Status {
        job_id: String,
    },
}

#[derive(Subcommand)]
enum QueueCommands {
    /// 入队
    Enqueue {
        queue_name: String,
        message: String,
    },
    /// 出队
    Dequeue {
        queue_name: String,
    },
    /// 查看
    Peek {
        queue_name: String,
    },
    /// 队列大小
    Size {
        queue_name: String,
    },
}

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    let cli = Cli::parse();
    let client = EvifClient::new("http://localhost:8080")?;

    match cli.command {
        Commands::Ls { path, limit, detailed } => {
            cmd_ls(client, path, limit, detailed).await?
        },
        Commands::Cat { path, offset, size } => {
            cmd_cat(client, path, offset, size).await?
        },
        Commands::Write { path, content, file, append } => {
            cmd_write(client, path, content, file, append).await?
        },
        Commands::Rm { path, recursive, force } => {
            cmd_rm(client, path, recursive, force).await?
        },
        Commands::Mkdir { path, mode, parents } => {
            cmd_mkdir(client, path, mode, parents).await?
        },
        Commands::Mv { src, dst } => {
            cmd_mv(client, src, dst).await?
        },
        Commands::Cp { src, dst } => {
            cmd_cp(client, src, dst).await?
        },
        Commands::Stat { path, json } => {
            cmd_stat(client, path, json).await?
        },
        Commands::Mount { plugin, path, config } => {
            cmd_mount(client, plugin, path, config).await?
        },
        Commands::Unmount { path } => {
            cmd_unmount(client, path).await?
        },
        Commands::Mounts => {
            cmd_mounts(client).await?
        },
        Commands::Repl => {
            run_repl(client).await?
        },
        Commands::Grep { path, pattern, limit } => {
            cmd_grep(client, path, pattern, limit).await?
        },
        Commands::Vector { cmd } => {
            cmd_vector(client, cmd).await?
        },
        Commands::Gpt { cmd } => {
            cmd_gpt(client, cmd).await?
        },
        Commands::Queue { cmd } => {
            cmd_queue(client, cmd).await?
        },
        Commands::Health => {
            cmd_health(client).await?
        },
        Commands::ServerInfo => {
            cmd_server_info(client).await?
        },
        Commands::Version => {
            println!("EVIF version {}", env!("CARGO_PKG_VERSION"));
        },
    }

    Ok(())
}
```

