## 🎯 Phase 4: Python SDK (Week 4)

### 目标
提供易用的 Python SDK,支持异步操作和重试机制

### SDK 结构

```python
# evif/client.py

import asyncio
from typing import Optional, List
from dataclasses import dataclass
import httpx

@dataclass
class FileInfo:
    name: str
    size: int
    mode: int
    modified: str
    is_dir: bool

class EvifClient:
    """EVIF Python SDK"""

    def __init__(
        self,
        base_url: str = "http://localhost:8080",
        timeout: float = 30.0,
        max_retries: int = 3,
    ):
        self.base_url = base_url
        self.timeout = timeout
        self.max_retries = max_retries
        self._client = None

    async def __aenter__(self):
        self._client = httpx.AsyncClient(
            base_url=self.base_url,
            timeout=self.timeout,
        )
        return self

    async def __aexit__(self, *args):
        if self._client:
            await self._client.aclose()

    async def ls(
        self,
        path: str,
        limit: Optional[int] = None,
    ) -> List[FileInfo]:
        """列出目录内容"""
        params = {"path": path}
        if limit:
            params["limit"] = limit

        response = await self._client.get("/api/v1/directories", params=params)
        response.raise_for_status()
        data = response.json()

        return [FileInfo(**item) for item in data["files"]]

    async def cat(
        self,
        path: str,
        offset: int = 0,
        size: int = 0,
        stream: bool = False,
    ) -> bytes:
        """读取文件内容"""
        params = {"path": path, "offset": offset}
        if size > 0:
            params["size"] = size

        if stream:
            return await self._cat_stream(params)

        response = await self._client.get("/api/v1/files", params=params)
        response.raise_for_status()
        return response.content

    async def write(
        self,
        path: str,
        content: Union[str, bytes],
        offset: int = -1,
        flags: WriteFlags = WriteFlags.CREATE,
    ) -> int:
        """写入文件"""
        if isinstance(content, str):
            content = content.encode()

        params = {"path": path, "offset": offset, "flags": flags.value}
        response = await self._client.put("/api/v1/files", params=params, content=content)
        response.raise_for_status()
        data = response.json()
        return data["bytes_written"]

    async def open_handle(
        self,
        path: str,
        flags: OpenFlags = OpenFlags.READ_ONLY,
        mode: int = 0o644,
        lease: int = 60,
    ) -> FileHandle:
        """打开文件句柄"""
        response = await self._client.post(
            "/api/v1/handles",
            json={
                "path": path,
                "flags": flags.value,
                "mode": mode,
                "lease_seconds": lease,
            },
        )
        response.raise_for_status()
        data = response.json()
        return FileHandle(
            id=data["id"],
            path=data["path"],
            client=self,
        )

    # ... 其他方法

    async def _cat_stream(self, params: dict) -> bytes:
        """流式读取大文件"""
        async with self._client.stream("GET", "/api/v1/files", params=params) as response:
            response.raise_for_status()
            chunks = []
            async for chunk in response.aiter_bytes():
                chunks.append(chunk)
            return b"".join(chunks)

# evif/file_handle.py

@dataclass
class FileHandle:
    id: int
    path: str
    client: EvifClient
    _offset: int = 0

    async def read(self, size: int = 4096) -> bytes:
        """从句柄读取"""
        response = await self.client._client.post(
            f"/api/v1/handles/{self.id}/read",
            json={"offset": self._offset, "size": size},
        )
        response.raise_for_status()
        data = response.json()
        content = bytes.fromhex(data["data"])
        self._offset += len(content)
        return content

    async def write(self, data: bytes) -> int:
        """向句柄写入"""
        response = await self.client._client.post(
            f"/api/v1/handles/{self.id}/write",
            json={"offset": self._offset, "data": data.hex()},
        )
        response.raise_for_status()
        result = response.json()
        self._offset += result["bytes_written"]
        return result["bytes_written"]

    async def close(self):
        """关闭句柄"""
        await self.client._client.delete(f"/api/v1/handles/{self.id}")

    async def __aenter__(self):
        return self

    async def __aexit__(self, *args):
        await self.close()
```

### 示例代码

```python
# examples/basic_usage.py

import asyncio
from evif import EvifClient

async def main():
    async with EvifClient("http://localhost:8080") as client:
        # 列出文件
        files = await client.ls("/local/projects")
        for file in files:
            print(f"  {file.name} ({file.size} bytes)")

        # 读取文件
        content = await client.cat("/local/README.md")
        print(content.decode())

        # 写入文件
        await client.write("/local/test.txt", "Hello, EVIF!")

        # 使用句柄处理大文件
        async with await client.open_handle("/local/large.bin") as handle:
            while True:
                chunk = await handle.read(4096)
                if not chunk:
                    break
                process_chunk(chunk)

asyncio.run(main())
```

