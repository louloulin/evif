**代码示例**:
```rust
use thiserror::Error;

#[derive(Error, Debug)]
pub enum EvifError {
    #[error("Path not found: {0}")]
    NotFound(String),

    #[error("Already mounted at: {0}")]
    AlreadyMounted(String),

    #[error("Permission denied: {0}")]
    PermissionDenied(String),

    #[error("Operation not supported by plugin: {plugin_name}")]
    NotSupported { plugin_name: String },

    #[error("IO error: {0}")]
    Io(#[from] std::io::Error),

    #[error("Serialization error: {0}")]
    Serde(#[from] serde_json::Error),

    #[error("HTTP error: {0}")]
    Http(String),
}
```

