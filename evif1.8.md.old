## 📋 Phase 1: HandleFS实现 (Week 1)

### 目标
实现文件句柄管理,支持随机访问和并发控制

### 核心设计

```rust
// evif-plugins/src/handlefs.rs

use async_trait::async_trait;
use std::collections::HashMap;
use std::sync::Arc;
use tokio::sync::{Mutex, RwLock};
use std::time::{Duration, Instant};

/// 文件打开标志
#[derive(Debug, Clone, Copy, PartialEq)]
pub struct OpenFlags(pub u32);

impl OpenFlags {
    pub const READ: u32 = 1;  // 只读
    pub const WRITE: u32 = 2;  // 只写
    pub const RDWR: u32 = 3;   // 读写
    pub const CREATE: u32 = 4;  // 创建
    pub const TRUNCATE: u32 = 8; // 截断
    pub const APPEND: u32 = 16; // 追加
}

/// Seek起始位置
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum SeekWhence {
    Set = 0,    // 从文件开始
    Current = 1, // 从当前位置
    End = 2,     // 从文件末尾
}

/// 文件句柄
#[derive(Debug, Clone)]
pub struct FileHandle {
    pub id: i64,
    pub path: String,
    pub flags: OpenFlags,
    pub mode: u32,
    pub offset: i64,
    pub created_at: Instant,
    pub expires_at: Instant,
    pub client: Arc<EvifClient>,
}

impl FileHandle {
    /// 检查句柄是否有效
    pub fn is_valid(&self) -> bool {
        Instant::now() < self.expires_at
    }

    /// 续租句柄
    pub async fn renew(&mut self, lease: Duration) -> EvifResult<()> {
        if !self.is_valid() {
            return Err(EvifError::HandleExpired(self.id));
        }
        self.expires_at = Instant::now() + lease;
        Ok(())
    }
}

/// HandleFS插件
pub struct HandleFsPlugin {
    base_fs: Arc<dyn EvifPlugin>,
    handles: Arc<RwLock<HashMap<i64, FileHandle>>>,
    next_handle_id: Arc<AtomicI64>,
    default_lease: Duration,
}

impl HandleFsPlugin {
    pub fn new(base_fs: Arc<dyn EvifPlugin>) -> Self {
        Self {
            base_fs,
            handles: Arc::new(RwLock::new(HashMap::new())),
            next_handle_id: Arc::new(AtomicI64::new(1)),
            default_lease: Duration::from_secs(60),
        }
    }

    /// 打开文件句柄
    pub async fn open(
        &self,
        path: &str,
        flags: OpenFlags,
        mode: u32,
        lease: Duration,
    ) -> EvifResult<i64> {
        // 检查文件是否存在
        let info = self.base_fs.stat(path).await?;

        // 创建新句柄
        let handle_id = self.next_handle_id.fetch_add(1);
        let handle = FileHandle {
            id: handle_id,
            path: path.to_string(),
            flags,
            mode,
            offset: 0,
            created_at: Instant::now(),
            expires_at: Instant::now() + lease,
            client: Arc::new(EvifClient::new("http://localhost:8080")), // TODO
        };

        // 存储句柄
        let mut handles = self.handles.write().await;
        handles.insert(handle_id, handle);

        Ok(handle_id)
    }

    /// 关闭文件句柄
    pub async fn close(&self, handle_id: i64) -> EvifResult<()> {
        let mut handles = self.handles.write().await;
        handles.remove(handle_id)
            .ok_or_else(|| EvifError::InvalidHandle(handle_id))?;
        Ok(())
    }

    /// 读取句柄数据
    pub async fn read(
        &self,
        handle_id: i64,
        size: usize,
    ) -> EvifResult<Vec<u8>> {
        let handles = self.handles.read().await;
        let handle = handles.get(&handle_id)
            .ok_or_else(|| EvifError::InvalidHandle(handle_id))?;

        if !handle.is_valid() {
            return Err(EvifError::HandleExpired(handle_id));
        }

        // 通过base_fs读取
        self.base_fs.read(&handle.path, handle.offset as u64, size as u64).await
    }

    /// 写入句柄数据
    pub async fn write(
        &self,
        handle_id: i64,
        data: Vec<u8>,
    ) -> EvifResult<usize> {
        let mut handles = self.handles.write().await;
        let handle = handles.get_mut(&handle_id)
            .ok_or_else(|| EvifError::InvalidHandle(handle_id))?;

        if !handle.is_valid() {
            return Err(EvifError::HandleExpired(handle_id));
        }

        // 写入并更新offset
        let written = self.base_fs.write(&handle.path, data, handle.offset, WriteFlags::EMPTY).await?;
        handle.offset += written as i64;

        Ok(written as usize)
    }

    /// 定位句柄
    pub async fn seek(
        &self,
        handle_id: i64,
        offset: i64,
        whence: SeekWhence,
    ) -> EvifResult<i64> {
        let mut handles = self.handles.write().await;
        let handle = handles.get_mut(&handle_id)
            .ok_or_else(|| EvifError::InvalidHandle(handle_id))?;

        let info = self.base_fs.stat(&handle.path).await?;
        let file_size = info.size as i64;

        let new_offset = match whence {
            SeekWhence::Set => offset,
            SeekWhence::Current => handle.offset + offset,
            SeekWhence::End => file_size + offset,
        };

        if new_offset < 0 || new_offset > file_size {
            return Err(EvifError::InvalidPath(format!("Invalid seek offset: {}", new_offset)));
        }

        handle.offset = new_offset;
        Ok(new_offset)
    }

    /// 同步句柄
    pub async fn sync(&self, handle_id: i64) -> EvifResult<()> {
        let handles = self.handles.read().await;
        let handle = handles.get(&handle_id)
            .ok_or_else(|| EvifError::InvalidHandle(handle_id))?;

        // 确保数据持久化
        self.base_fs.write(&handle.path, vec![], 0, WriteFlags::SYNC).await?;
        Ok(())
    }

    /// 清理过期句柄
    pub async fn cleanup_expired_handles(&self) -> EvifResult<usize> {
        let mut handles = self.handles.write().await;
        let now = Instant::now();

        let initial_count = handles.len();
        handles.retain(|_, handle| handle.is_valid());

        Ok(initial_count - handles.len())
    }
}

#[async_trait]
impl EvifPlugin for HandleFsPlugin {
    fn name(&self) -> &str {
        "HandleFS"
    }

    async fn create(&self, path: &str, perm: u32) -> EvifResult<()> {
        self.base_fs.create(path, perm).await
    }

    async fn mkdir(&self, path: &str, perm: u32) -> EvifResult<()> {
        self.base_fs.mkdir(path, perm).await
    }

    async fn read(&self, path: &str, offset: u64, size: u64) -> EvifResult<Vec<u8>> {
        self.base_fs.read(path, offset, size).await
    }

    async fn write(&self, path: &str, data: Vec<u8>, offset: i64, flags: WriteFlags) -> EvifResult<u64> {
        self.base_fs.write(path, data, offset, flags).await
    }

    async fn readdir(&self, path: &str) -> EvifResult<Vec<FileInfo>> {
        self.base_fs.readdir(path).await
    }

    async fn stat(&self, path: &str) -> EvifResult<FileInfo> {
        self.base_fs.stat(path).await
    }

    async fn remove(&self, path: &str) -> EvifResult<()> {
        self.base_fs.remove(path).await
    }

    async fn remove_all(&self, path: &str) -> EvifResult<()> {
        self.base_fs.remove_all(path).await
    }

    async fn rename(&self, old_path: &str, new_path: &str) -> EvifResult<()> {
        self.base_fs.rename(old_path, new_path).await
    }
}
```

### HTTP API端点

| 端点 | 方法 | 功能 |
|------|------|------|
| `/api/v1/handles` | POST | 打开文件句柄 |
| `/api/v1/handles/{id}` | DELETE | 关闭句柄 |
| `/api/v1/handles/{id}/read` | POST | 读取句柄 |
| `/api/v1/handles/{id}/write` | POST | 写入句柄 |
| `/api/v1/handles/{id}/seek` | POST | 定位句柄 |
| `/api/v1/handles/{id}/sync` | POST | 同步句柄 |
| `/api/v1/handles/{id}/renew` | POST | 续租句柄 |
| `/api/v1/handles` | GET | 列出所有句柄 |
| `/api/v1/handles/{id}` | GET | 获取句柄信息 |

### 测试

```rust
#[tokio::test]
async fn test_handlefs_open_read_close() {
    let base_fs = Arc::new(MemFsPlugin::new());
    let handlefs = HandleFsPlugin::new(base_fs);

    // 创建文件
    handlefs.create("/test.txt", 0o644).await.unwrap();
    handlefs.write("/test.txt", b"Hello, World!".to_vec(), 0, WriteFlags::CREATE).await.unwrap();

    // 打开句柄
    let handle_id = handlefs.open(
        "/test.txt",
        OpenFlags(OpenFlags::READ),
        0o644,
        Duration::from_secs(60),
    ).await.unwrap();

    // 读取
    let data = handlefs.read(handle_id, 13).await.unwrap();
    assert_eq!(data, b"Hello, World!");

    // 定位
    let new_offset = handlefs.seek(handle_id, 0, SeekWhence::Set).await.unwrap();
    assert_eq!(new_offset, 0);

    // 关闭
    handlefs.close(handle_id).await.unwrap();
}
```

