#### 0.2 统一错误处理

```rust
// evif-core/src/error.rs

pub enum EvifError {
    // 文件系统错误
    NotFound(String),
    AlreadyExists(String),
    PermissionDenied(String),
    InvalidPath(String),
    NotSupported(String),

    // 网络错误
    NetworkError(String),
    Timeout(String),

    // 插件错误
    PluginError(String),
    PluginNotFound(String),

    // HandleFS错误
    InvalidHandle(i64),
    HandleExpired(i64),

    // Agent错误
    AgentError(String),
    SkillNotFound(String),

    // 内部错误
    Internal(String),
}

pub type EvifResult<T> = Result<T, EvifError>;
```

#### 0.3 测试框架完善

```rust
// tests/common/mod.rs

pub struct TestContext {
    pub temp_dir: tempfile::TempDir,
    pub server: EvifServer,
    pub client: EvifClient,
}

impl TestContext {
    pub async fn new() -> EvifResult<Self> {
        let temp_dir = tempfile::tempdir()?;
        let server = EvifServer::new(&temp_dir.path()).await?;
        let client = EvifClient::new(server.url());
        Ok(Self { temp_dir, server, client })
    }
}
```

