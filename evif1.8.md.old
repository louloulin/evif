## 📋 Phase 4: Python SDK (Week 4)

### 目标
实现完整的Python客户端SDK

### 核心设计

```python
# evif-sdk-python/evif/client.py

import asyncio
import aiohttp
from typing import List, Dict, Optional, Union, AsyncIterator, BinaryIO
from dataclasses import dataclass
from datetime import datetime, timedelta

@dataclass
class FileInfo:
    name: str
    path: str
    size: int
    modified: datetime
    mode: int
    is_dir: bool

@dataclass
class MountPoint:
    plugin_type: str
    mount_path: str
    config: Dict

class EvifClient:
    """EVIF Python客户端"""

    def __init__(
        self,
        base_url: str = "http://localhost:8080",
        timeout: int = 30,
        max_retries: int = 3,
    ):
        self.base_url = base_url.rstrip('/')
        self.timeout = timeout
        self.max_retries = max_retries
        self._session: Optional[aiohttp.ClientSession] = None

    async def _get_session(self) -> aiohttp.ClientSession:
        if self._session is None or self._session.closed:
            timeout = aiohttp.ClientTimeout(total=self.timeout)
            self._session = aiohttp.ClientSession(timeout=timeout)
        return self._session

    async def _request(
        self,
        method: str,
        endpoint: str,
        **kwargs
    ) -> Dict:
        """发送HTTP请求"""
        session = await self._get_session()
        url = f"{self.base_url}{endpoint}"

        for attempt in range(self.max_retries):
            try:
                async with session.request(method, url, **kwargs) as response:
                    if response.status == 200:
                        return await response.json()
                    else:
                        error_data = await response.text()
                        raise Exception(f"HTTP {response.status}: {error_data}")
            except (aiohttp.ClientError, asyncio.TimeoutError) as e:
                if attempt == self.max_retries - 1:
                    raise
                await asyncio.sleep(2 ** attempt)  # 指数退避

    async def ls(self, path: str = "/") -> List[FileInfo]:
        """列出目录"""
        result = await self._request("GET", "/api/v1/files", params={"path": path})
        return [FileInfo(**item) for item in result]

    async def cat(
        self,
        path: str,
        offset: int = 0,
        size: int = -1,
        stream: bool = False
    ) -> Union[bytes, AsyncIterator[bytes]]:
        """读取文件"""
        if stream:
            # 流式读取
            session = await self._get_session()
            url = f"{self.base_url}/api/v1/files"
            params = {"path": path, "offset": offset, "size": size, "stream": True}

            async with session.get(url, params=params) as response:
                response.raise_for_status()
                async for chunk in response.content.iter_chunked():
                    yield chunk
        else:
            result = await self._request("GET", "/api/v1/files", params={
                "path": path,
                "offset": offset,
                "size": size
            })
            return result["content"]

    async def write(
        self,
        path: str,
        content: Union[str, bytes],
        max_retries: int = 3,
    ) -> Dict:
        """写入文件"""
        if isinstance(content, str):
            content = content.encode()

        result = await self._request("PUT", "/api/v1/files", data=content, params={
            "path": path,
            "max_retries": max_retries
        })
        return result

    async def create(self, path: str) -> Dict:
        """创建文件"""
        return await self._request("POST", "/api/v1/files", json={"path": path})

    async def mkdir(self, path: str, mode: str = "0755") -> Dict:
        """创建目录"""
        return await self._request("POST", "/api/v1/directories", json={
            "path": path,
            "mode": int(mode, 8)
        })

    async def rm(self, path: str, recursive: bool = False) -> Dict:
        """删除文件/目录"""
        return await self._request("DELETE", "/api/v1/files", params={
            "path": path,
            "recursive": recursive
        })

    async def stat(self, path: str) -> FileInfo:
        """获取文件信息"""
        result = await self._request("GET", "/api/v1/stat", params={"path": path})
        return FileInfo(**result)

    async def mv(self, old_path: str, new_path: str) -> Dict:
        """移动/重命名"""
        return await self._request("POST", "/api/v1/rename", json={
            "old_path": old_path,
            "new_path": new_path
        })

    async def chmod(self, path: str, mode: int) -> Dict:
        """修改权限"""
        return await self._request("POST", "/api/v1/chmod", json={
            "path": path,
            "mode": mode
        })

    async def truncate(self, path: str, size: int) -> Dict:
        """截断文件"""
        return await self._request("POST", "/api/v1/truncate", json={
            "path": path,
            "size": size
        })

    async def grep(
        self,
        path: str,
        pattern: str,
        recursive: bool = False,
        case_insensitive: bool = False,
        stream: bool = False,
    ) -> Dict:
        """正则搜索"""
        return await self._request("POST", "/api/v1/grep", json={
            "path": path,
            "pattern": pattern,
            "recursive": recursive,
            "case_insensitive": case_insensitive,
            "stream": stream
        })

    async def digest(
        self,
        path: str,
        algorithm: str = "xxh3"
    ) -> Dict:
        """文件摘要"""
        return await self._request("POST", "/api/v1/digest", json={
            "path": path,
            "algorithm": algorithm
        })

    # HandleFS API
    async def open_handle(
        self,
        path: str,
        flags: int = 1,  # READ
        mode: int = 0o644,
        lease: int = 60,
    ) -> "FileHandle":
        """打开文件句柄"""
        from evif.file_handle import FileHandle

        result = await self._request("POST", "/api/v1/handles", json={
            "path": path,
            "flags": flags,
            "mode": mode,
            "lease": lease
        })
        handle_id = result["handle_id"]
        return FileHandle(self, handle_id)

    async def mounts(self) -> List[MountPoint]:
        """列出挂载点"""
        result = await self._request("GET", "/api/v1/mounts")
        return [MountPoint(**item) for item in result]

    async def mount(
        self,
        fstype: str,
        path: str,
        config: Dict,
    ) -> Dict:
        """挂载插件"""
        return await self._request("POST", "/api/v1/mount", json={
            "plugin_type": fstype,
            "mount_path": path,
            "config": config
        })

    async def unmount(self, path: str) -> Dict:
        """卸载插件"""
        return await self._request("POST", "/api/v1/unmount", json={"path": path})

    async def close(self):
        """关闭客户端"""
        if self._session and not self._session.closed:
            await self._session.close()
```

