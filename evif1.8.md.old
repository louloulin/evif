## 📋 Phase 2: MCP服务器 (Week 2)

### 目标
实现MCP (Model Context Protocol) 服务器,深度集成Claude

### 核心设计

```rust
// evif-mcp/src/lib.rs

use jsonrpsee::core::Params;
use jsonrpsee::proc_macros::Rpc;
use jsonrpsee::routing::Router;
use serde::{Deserialize, Serialize};
use serde_json::Value;
use std::sync::Arc;
use tokio::sync::RwLock;

/// MCP服务器
pub struct EvifMcpServer {
    evif_client: Arc<EvifClient>,
    tools: Vec<Tool>,
    prompts: Vec<Prompt>,
    resources: Vec<Resource>,
}

/// MCP工具定义
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Tool {
    name: String,
    description: String,
    input_schema: serde_json::Value,
}

/// MCP Prompt定义
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Prompt {
    name: String,
    description: String,
    arguments: Vec<PromptArgument>,
}

/// MCP Prompt参数
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct PromptArgument {
    name: String,
    description: String,
    required: bool,
}

/// MCP资源
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Resource {
    uri: String,
    name: String,
    description: String,
    mime_type: String,
}

impl EvifMcpServer {
    pub fn new(base_url: String) -> Self {
        let client = Arc::new(EvifClient::new(base_url));

        let mut server = Self {
            evif_client: client,
            tools: Vec::new(),
            prompts: Vec::new(),
            resources: Vec::new(),
        };

        server.register_default_tools();
        server.register_default_prompts();

        server
    }

    /// 注册默认工具
    fn register_default_tools(&mut self) {
        // 文件操作工具
        self.tools.push(Tool {
            name: "evif_read".to_string(),
            description: "读取文件内容".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "文件路径"
                    },
                    "offset": {
                        "type": "number",
                        "description": "读取偏移量",
                        "default": 0
                    },
                    "size": {
                        "type": "number",
                        "description": "读取大小",
                        "default": -1
                    }
                },
                "required": ["path"]
            }),
        });

        self.tools.push(Tool {
            name: "evif_write".to_string(),
            description: "写入文件内容".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "文件路径"
                    },
                    "content": {
                        "type": "string",
                        "description": "文件内容"
                    }
                },
                "required": ["path", "content"]
            }),
        });

        self.tools.push(Tool {
            name: "evif_list".to_string(),
            description: "列出目录内容".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "目录路径"
                    }
                },
                "required": ["path"]
            }),
        });

        self.tools.push(Tool {
            name: "evif_stat".to_string(),
            description: "获取文件信息".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "文件路径"
                    }
                },
                "required": ["path"]
            }),
        });

        self.tools.push(Tool {
            name: "evif_search".to_string(),
            description: "搜索文件内容".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {
                    "path": {
                        "type": "string",
                        "description": "搜索路径"
                    },
                    "pattern": {
                        "type": "string",
                        "description": "搜索模式"
                    },
                    "recursive": {
                        "type": "boolean",
                        "description": "递归搜索",
                        "default": false
                    }
                },
                "required": ["path", "pattern"]
            }),
        });

        // 挂载管理工具
        self.tools.push(Tool {
            name: "evif_mounts".to_string(),
            description: "列出所有挂载点".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {},
                "required": []
            }),
        });

        self.tools.push(Tool {
            name: "evif_mount".to_string(),
            description: "挂载插件".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {
                    "plugin_type": {
                        "type": "string",
                        "description": "插件类型"
                    },
                    "mount_path": {
                        "type": "string",
                        "description": "挂载路径"
                    },
                    "config": {
                        "type": "object",
                        "description": "插件配置"
                    }
                },
                "required": ["plugin_type", "mount_path"]
            }),
        });

        self.tools.push(Tool {
            name: "evif_unmount".to_string(),
            description: "卸载插件".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {
                    "mount_path": {
                        "type": "string",
                        "description": "挂载路径"
                    }
                },
                "required": ["mount_path"]
            }),
        });
    }

    /// 注册默认Prompt
    fn register_default_prompts(&mut self) {
        self.prompts.push(Prompt {
            name: "file_explorer".to_string(),
            description: "文件浏览器 - 帮助用户浏览和管理文件系统".to_string(),
            arguments: vec![
                PromptArgument {
                    name: "root_path".to_string(),
                    description: "根目录路径".to_string(),
                    required: false,
                },
            ],
        });

        self.prompts.push(Prompt {
            name: "code_analyzer".to_string(),
            description: "代码分析器 - 分析代码结构和质量".to_string(),
            arguments: vec![
                PromptArgument {
                    name: "target_path".to_string(),
                    description: "目标代码路径".to_string(),
                    required: true,
                },
            ],
        });

        self.prompts.push(Prompt {
            name: "log_analyzer".to_string(),
            description: "日志分析器 - 分析日志文件并提供洞察".to_string(),
            arguments: vec![
                PromptArgument {
                    name: "log_path".to_string(),
                    description: "日志文件路径".to_string(),
                    required: true,
                },
            ],
        });
    }
}

/// JSON-RPC Handler实现
#[derive(Clone)]
pub struct McpHandler {
    server: Arc<RwLock<EvfsMcpServer>>,
}

impl McpHandler {
    pub async fn tools_list(&self) -> Vec<Tool> {
        let server = self.server.read().await;
        server.tools.clone()
    }

    pub async fn tools_call(&self, name: String, args: Value) -> Result<Value, jsonrpsee::core::Error> {
        let server = self.server.read().await;

        match name.as_str() {
            "evif_read" => {
                let path = args.get("path")
                    .and_then(|v| v.as_str())
                    .ok_or_else(|| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::InvalidData,
                        "Missing 'path' parameter"
                    )))?;

                let offset = args.get("offset")
                    .and_then(|v| v.as_i64())
                    .unwrap_or(0) as u64;

                let size = args.get("size")
                    .and_then(|v| v.as_i64())
                    .unwrap_or(-1) as u64;

                let data = server.evil_client.read(path, offset, size).await
                    .map_err(|e| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::Other,
                        e.to_string()
                    ))?;

                Ok(serde_json::json!({
                    "content": String::from_utf8_lossy(&data),
                    "size": data.len()
                }))
            }

            "evif_write" => {
                let path = args.get("path")
                    .and_then(|v| v.as_str())
                    .ok_or_else(|| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::InvalidData,
                        "Missing 'path' parameter"
                    )))?;

                let content = args.get("content")
                    .and_then(|v| v.as_str())
                    .ok_or_else(|| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::InvalidData,
                        "Missing 'content' parameter"
                    )))?;

                let written = server.evil_client.write(path, content.as_bytes().to_vec()).await
                    .map_err(|e| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::Other,
                        e.to_string()
                    ))?;

                Ok(serde_json::json!({
                    "bytes_written": written
                }))
            }

            "evif_list" => {
                let path = args.get("path")
                    .and_then(|v| v.as_str())
                    .ok_or_else(|| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::InvalidData,
                        "Missing 'path' parameter"
                    )))?;

                let entries = server.evil_client.list(path).await
                    .map_err(|e| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::Other,
                        e.to_string()
                    ))?;

                Ok(serde_json::to_value(entries).unwrap())
            }

            "evif_search" => {
                let path = args.get("path")
                    .and_then(|v| v.as_str())
                    .ok_or_else(|| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::InvalidData,
                        "Missing 'path' parameter"
                    )))?;

                let pattern = args.get("pattern")
                    .and_then(|v| v.as_str())
                    .ok_or_else(|| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::InvalidData,
                        "Missing 'pattern' parameter"
                    )))?;

                let recursive = args.get("recursive")
                    .and_then(|v| v.as_bool())
                    .unwrap_or(false);

                let results = server.evil_client.search(path, pattern, recursive).await
                    .map_err(|e| jsonrpsee::core::Error::from(std::io::Error::new(
                        std::io::ErrorKind::Other,
                        e.to_string()
                    ))?;

                Ok(serde_json::to_value(results).unwrap())
            }

            _ => Err(jsonrpsee::core::Error::from(std::io::Error::new(
                std::io::ErrorKind::NotFound,
                format!("Unknown tool: {}", name)
            )))
        }
    }
}

/// 启动MCP服务器 (stdio模式)
pub async fn run_stdio_server() -> Result<()> {
    let server = EvifMcpServer::new("http://localhost:8080".to_string());

    let handler = McpHandler {
        server: Arc::new(RwLock::new(server)),
    };

    let mut router = Router::new(handler)
        .method("tools/list", handler.tools_list)
        .method("tools/call", handler.tools_call);

    // 启动stdio服务器
    jsonrpsee::server::Server::builder()
        .set_rpc_middleware(rpc::RpcLayer)
        .build(router)
        .await?
        .start(std::io::stdin(), std::io::stdout())
        .await?;

    Ok(())
}
```

