## 📋 Phase 7: 监控和指标 (Week 7)

### 目标
实现企业级监控和指标收集

### 核心设计

```rust
// evif-metrics/src/lib.rs

use prometheus::{Counter, Histogram, IntGauge, Registry};
use std::sync::Arc;
use tokio::sync::RwLock;

/// EVIF指标收集器
pub struct EvifMetrics {
    registry: Registry,
    requests_total: Counter,
    request_duration: Histogram,
    active_handles: IntGauge,
    plugin_errors: Counter,
}

impl EvifMetrics {
    pub fn new() -> Self {
        let registry = Registry::new();

        let requests_total = Counter::new(
            "evif_requests_total",
            "Total number of requests",
            registry
        ).unwrap();

        let request_duration = Histogram::with_opts(
            "evif_request_duration_seconds",
            "Request duration in seconds",
            prometheus::HistogramOpts::new(vec![
                vec![0.001, 0.005, 0.01, 0.05, 0.1, 0.5, 1.0, 5.0, 10.0],
            ]),
            registry
        ).unwrap();

        let active_handles = IntGauge::new(
            "evif_active_handles",
            "Number of active file handles",
            registry
        ).unwrap();

        let plugin_errors = Counter::new(
            "evif_plugin_errors_total",
            "Total number of plugin errors",
            registry
        ).unwrap();

        Self {
            registry,
            requests_total,
            request_duration,
            active_handles,
            plugin_errors,
        }
    }

    pub fn start_request(&self) {
        self.requests_total.inc();
    }

    pub fn finish_request(&self, duration: f64) {
        self.request_duration.observe(duration);
    }
}
```

