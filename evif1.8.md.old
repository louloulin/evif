## 📋 Phase 6: 增强CLI (Week 6)

### 目标
实现功能完整的命令行工具

### 核心设计

```rust
// evif-cli/src/main.rs

use clap::{Parser, Subcommand};
use evif_client::EvifClient;

#[derive(Parser)]
#[command(name = "evif")]
#[command(about = "EVIF - 智能文件系统命令行工具", long_about = None)]
struct EvifCli {
    #[command(subcommand)]
    command: Commands,
}

#[derive(Subcommand)]
enum Commands {
    /// 列出目录内容
    Ls {
        /// 文件路径
        path: String,
        /// 显示详细信息
        #[arg(short, long)]
        detailed: bool,
        /// 递归列出
        #[arg(short, long)]
        recursive: bool,
    },

    /// 读取文件内容
    Cat {
        /// 文件路径
        path: String,
        /// 起始偏移
        #[arg(short, long, default_value = "0")]
        offset: u64,
        /// 读取大小
        #[arg(short, long, default_value = "0")]
        size: u64,
        /// 流式输出
        #[arg(long)]
        stream: bool,
    },

    /// 写入文件
    Write {
        /// 文件路径
        path: String,
        /// 文件内容
        content: String,
        /// 从stdin读取
        #[arg(long)]
        stdin: bool,
    },

    /// 创建目录
    Mkdir {
        /// 目录路径
        path: String,
        /// 权限模式
        #[arg(short, long, default_value = "755")]
        mode: String,
    },

    /// 删除文件/目录
    Rm {
        /// 文件路径
        path: String,
        /// 递归删除
        #[arg(short, long)]
        recursive: bool,
        /// 强制删除
        #[arg(short, long)]
        force: bool,
    },

    /// 移动/重命名
    Mv {
        /// 源路径
        #[arg()]
        source: String,
        /// 目标路径
        #[arg()]
        destination: String,
    },

    /// 搜索文件内容
    Grep {
        /// 搜索路径
        path: String,
        /// 搜索模式
        pattern: String,
        /// 递归搜索
        #[arg(short, long)]
        recursive: bool,
        /// 忽略大小写
        #[arg(short, long)]
        ignore_case: bool,
    },

    /// 文件信息
    Stat {
        /// 文件路径
        path: String,
    },

    /// 挂载插件
    Mount {
        /// 插件类型
        plugin_type: String,
        /// 挂载路径
        mount_path: String,
        /// 配置参数(JSON)
        config: String,
    },

    /// 卸载插件
    Unmount {
        /// 挂载路径
        mount_path: String,
    },

    /// 列出挂载点
    Mounts,

    /// Agent模式
    Agent {
        /// 提示词模板
        prompt: String,
        /// 输入参数(JSON)
        params: String,
    },
}

async fn main() -> Result<(), Box<dyn std::error::Error>> {
    let cli = EvifCli::parse();
    let client = EvifClient::new("http://localhost:8080").await;

    match cli.command {
        Commands::Ls { path, detailed, recursive } => {
            if detailed {
                let entries = client.ls(&path).await?;
                for entry in entries {
                    println!("{:?} {}", entry.mode, entry.name);
                }
            } else {
                let entries = client.ls(&path).await?;
                for entry in entries {
                    println!("{}", entry.name);
                }
            }
        }
        // ... 其他命令实现
    }
}
```

