## 📋 Phase 5: FUSE集成 (Week 5)

### 目标
实现FUSE文件系统,支持本地挂载

### 核心设计

```rust
// evif-fuse/src/lib.rs

use fuser::*;
use std::ffi::OsStr;
use std::fs::File;
use std::sync::Arc;
use tokio::sync::RwLock;

/// EVIF FUSE文件系统
pub struct EvifFuse {
    client: Arc<EvifClient>,
    cache: Arc<RwLock<HashMap<std::path::PathBuf, (FileAttr, SystemTime)>>>,
    cache_ttl: Duration,
    attr_timeout: Duration,
}

impl EvifFuse {
    pub fn new(client: Arc<EvifClient>) -> Self {
        Self {
            client,
            cache: Arc::new(RwLock::new(HashMap::new())),
            cache_ttl: Duration::from_secs(5), // 5秒属性缓存
            attr_timeout: Duration::from_secs(1),
        }
    }

    fn convert_file_info(info: FileInfo) -> FileAttr {
        FileAttr {
            ino: 1, // 简化实现
            size: info.size,
            blocks: (info.size + 511) / 512,
            atime: info.modified.into(),
            mtime: info.modified.into(),
            ctime: info.modified.into(),
            crtime: info.modified.into(),
            kind: if info.is_dir {
                FileType::Directory
            } else {
                FileType::RegularFile
            },
            perm: info.mode as u16,
            nlink: 1,
            uid: 501,
            gid: 20,
            rdev: 0,
            flags: 0,
        }
    }
}

impl Filesystem for EvifFuse {
    fn lookup(&mut self, _req: &Request, parent: Ino, name: &OsStr) -> Result<Entry> {
        let name = name.to_string_lossy();

        // 检查缓存
        let cache = self.cache.read().unwrap();
        let path = if parent == 1 {
            std::path::PathBuf::from("/").join(&name)
        } else {
            // TODO: 实现完整路径解析
            return Err(fuser::libc::ENOENT);
        };

        if let Some((attr, _)) = cache.get(&path) {
            if attr.atime + self.cache_ttl.elapsed() > SystemTime::now() {
                drop(cache);
                let mut cache = self.cache.write().unwrap();
                cache.remove(&path);
            } else {
                return Ok(Entry {
                    inode: parent + 1, // 简化
                    attr: *attr,
                    generation: 0,
                });
            }
        }

        // 从服务器获取
        let path_str = path.to_string_lossy();
        tokio_runtime::block_on(async {
            match self.client.stat(&path_str).await {
                Ok(info) => {
                    let attr = Self::convert_file_info(info);
                    let mut cache = self.cache.write().await;
                    cache.insert(path, (attr, SystemTime::now()));
                    Ok(Entry {
                        inode: parent + 1,
                        attr,
                        generation: 0,
                    })
                }
                Err(_) => Err(fuser::libc::ENOENT),
            }
        })
    }

    fn getattr(&mut self, _req: &Request, ino: Ino) -> Result<FileAttr> {
        // TODO: 实现完整getattr
        Ok(FileAttr {
            ino,
            size: 0,
            blocks: 0,
            atime: SystemTime::now(),
            mtime: SystemTime::now(),
            ctime: SystemTime::now(),
            crtime: SystemTime::now(),
            kind: FileType::Directory,
            perm: 0o755,
            nlink: 1,
            uid: 501,
            gid: 20,
            rdev: 0,
            flags: 0,
        })
    }

    fn readdir(&mut self, _req: &Request, ino: Ino, _handle: Inode) -> Result<dyn DirectoryEntryStream> {
        // TODO: 实现readdir
        Ok(vec![].into_iter())
    }

    fn read(
        &mut self,
        _req: &Request,
        ino: Inode,
        _fh: Inode,
        offset: u64,
        size: u32,
        _flags: i32,
        _lock: Option<u64>,
    ) -> Result<usize> {
        // TODO: 实现read
        Err(fuser::libc::ENOSYS)
    }

    fn write(
        &mut self,
        _req: &Request,
        ino: Ino,
        _fh: Inode,
        offset: u64,
        data: &[u8],
        _size: u32,
        _flags: i32,
        _lock: Option<u64>,
    ) -> Result<usize> {
        // TODO: 实现write
        Err(fuser::libc::ENOSYS)
    }

    fn flush(
        &mut self,
        _req: &Request,
        _ino: Ino,
        _fh: Inode,
        _sync: bool,
    ) -> Result<()> {
        Ok(())
    }
}
```

